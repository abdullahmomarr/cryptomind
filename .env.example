# Copy to ".env" (or export in your shell) only if you want an LLM reasoning engine.
# The rule-based engine and all memory/data code run WITHOUT any key.

# Free LLM backend — Google Gemini (get a free key at https://aistudio.google.com).
# This is the recommended LLM engine; it works on the deployed app too.
GEMINI_API_KEY=your-free-gemini-key-here

# Optional paid alternative — Anthropic Claude.
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: exchange for live/historical data. Default is "binance" (works locally).
# Binance is geo-blocked on most cloud hosts, so set this to "kraken" when deploying.
# CRYPTOMIND_EXCHANGE=kraken
